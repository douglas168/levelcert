    subgraph BEFORE["⚠️ 資料切分前的不平衡情況 (Class Imbalance)"]
        M1[("多數類別\nMajority Class\n●●●●●●●●●●\n900 samples")]
        M2[("少數類別\nMinority Class\n★★★★★\n100 samples")]
